# Copier vers .env pour le développement local.
# En production, configurer ces variables dans Netlify (Site settings → Environment variables).

# Clé API Google Maps (géocodage, vue satellite, calcul de superficie)
GOOGLE_MAPS_API_KEY=

# Secret de signature des sessions (générer une longue chaîne aléatoire)
SESSION_SECRET=

# Mot de passe initial du compte d'Alex créé par `npm run seed`
SEED_ALEX_PASSWORD=

# Base de données PostgreSQL. Laisser vide en local (PGlite dans .data/pglite).
# Sur Netlify, NETLIFY_DATABASE_URL est fournie automatiquement par Netlify DB.
# DATABASE_URL=

# Passe 2 — intégration Square (production)
SQUARE_APPLICATION_ID=
SQUARE_ACCESS_TOKEN=

# Webhook Square (Developer Dashboard → Webhooks → Subscriptions).
# La clé de signature est fournie par Square; l'URL doit être EXACTEMENT
# celle configurée dans Square (utilisée pour vérifier la signature HMAC).
SQUARE_WEBHOOK_SIGNATURE_KEY=
SQUARE_WEBHOOK_NOTIFICATION_URL=https://mainappsav.netlify.app/api/webhooks/square
